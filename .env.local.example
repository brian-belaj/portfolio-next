# ─── SMTP — Contact Form ──────────────────────────────────────────────────────
# Copia questo file in .env.local e compila i valori reali.
# .env.local NON viene committato in git (già in .gitignore).

# Host SMTP del tuo provider (es. smtp.gmail.com, smtp-relay.brevo.com, ...)
SMTP_HOST=smtp.gmail.com

# Porta: 587 (STARTTLS, consigliata) oppure 465 (SSL/TLS)
SMTP_PORT=587

# Imposta "true" solo se usi la porta 465 (SSL diretto)
SMTP_SECURE=false

# Credenziali SMTP
SMTP_USER=tua-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx   # App Password Gmail oppure API key del provider

# Indirizzo mittente visualizzato nell'email (default: SMTP_USER)
SMTP_FROM_EMAIL=noreply@tuodominio.it

# Indirizzo a cui arrivano i messaggi del form contatti
CONTACT_TO_EMAIL=brian@tuodominio.it

# ─── (Opzionale) Backend Symfony — non più necessario per progetti e contatti ──
# NEXT_PUBLIC_API_URL=https://api.tuodominio.it/api
